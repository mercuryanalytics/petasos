# frozen_string_literal: true

source 'https://rubygems.org'
git_source(:github) {|repo| "https://github.com/#{repo}.git" }

ruby '3.3.4'

# Bundle edge Rails instead: gem 'rails', github: 'rails/rails'
gem 'rails', '~> 7.1.0'
# Use mysql as the database for Active Record
# gem 'mysql2', '>= 0.4.4'
gem 'pg', '~> 1.5'
# Build JSON APIs with ease. Read more: https://github.com/rails/jbuilder
# gem 'jbuilder', '~> 2.7'
# Use Redis adapter to run Action Cable in production
# gem 'redis', '~> 4.0'
# Use Active Model has_secure_password
# gem 'bcrypt', '~> 3.1.7'

# Use Active Storage variant
# gem 'image_processing', '~> 1.2'

# Reduces boot times through caching; required in config/boot.rb
gem 'bootsnap', '>= 1.4.2', require: false

gem 'jwt', '~> 2.2', '>= 2.2.1'
# Use Rack CORS for handling Cross-Origin Resource Sharing (CORS), making cross-origin AJAX possible
gem 'rack-cors'

# TODO: remove once Passenger activates the Gemfile-pinned base64 instead of the
# Ruby default gem. Ruby 3.3 ships base64 0.2.0 and Passenger preloads it before
# Bundler runs, causing a Gem::LoadError if Gemfile.lock resolves to a newer version.
gem 'base64', '~> 0.2.0'

# Same Passenger/default-gem activation issue as base64 above. Ruby 3.3.4 ships
# stringio 3.1.1; lockfile must not unlock it. Guarded by bin/check_gem_versions.sh.
gem 'stringio', '= 3.1.1'

gem 'cancancan', '~> 3.3.0'

gem 'rswag-api', '~> 2.17.0', require: 'rswag/api'
gem 'rswag-ui', '~> 2.17.0', require: 'rswag/ui'

gem 'rest-client', '~> 2.1'
gem 'interactor', '~> 3.1', '>= 3.1.2'
gem 'active_model_serializers', '~> 0.10.13'
gem 'aws-sdk-s3', require: false
gem 'active_storage_base64', '~> 3.0'
gem 'ed25519', '>= 1.2', '< 2.0'
gem 'bcrypt_pbkdf', '>= 1.0', '< 2.0'

group :development, :test do
  # Dev/test web server. Production runs Passenger Standalone.
  gem 'puma', '~> 6.4'

  # Call 'byebug' anywhere in the code to stop execution and get a debugger console
  gem 'byebug', platforms: %i[mri windows]
  gem "pry-rails"
  gem "pry-byebug"

  gem 'rspec-rails', '~> 6.1'
  gem 'rswag-specs', '~> 2.17.0', require: 'rswag/specs'
end

